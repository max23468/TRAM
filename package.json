{
  "name": "tram",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "demo:extract-text": "node scripts/build-demo-text-extracts.mjs",
    "demo:inventory": "node scripts/build-demo-inventory.mjs",
    "quality:react-doctor": "react-doctor --full --fail-on error .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "postbuild": "node scripts/normalize-next-env.mjs",
    "postinstall": "patch-package",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.16.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.12.4",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "patch-package": "8.0.1",
    "react-doctor": "^0.2.14",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "overrides": {
    "postcss": "8.5.15"
  }
}
