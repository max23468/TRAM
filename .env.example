# TRAM local development defaults. Do not put real secrets in this file.

TRAM_STORAGE_DRIVER=filesystem
TRAM_LOCAL_STORAGE_ROOT=.local/tram-storage

# OCI Object Storage target for the shared MVP.
# Leave these empty until bucket, IAM and runtime are approved in the OCI runbook.
TRAM_OCI_REGION=
TRAM_OCI_NAMESPACE=
TRAM_OCI_BUCKET_DOCUMENTS=
TRAM_OCI_COMPARTMENT_ID=
TRAM_OCI_AUTH_MODE=instance_principal

# Safety limits for uploads. Values are intentionally unset in Slice 0.
TRAM_MAX_DOCUMENT_BYTES=
TRAM_MAX_SPACE_STORAGE_BYTES=
